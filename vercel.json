{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/((?!john-).*)", "destination": "http://187.127.29.117:8000/$1" }
  ],
  "redirects": [
    { "source": "/auditoria",        "destination": "/app", "permanent": false },
    { "source": "/iniciar",          "destination": "/app", "permanent": false },
    { "source": "/comecar",          "destination": "/app", "permanent": false },
